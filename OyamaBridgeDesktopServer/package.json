{
  "name": "oyama-bridge-desktop-server",
  "version": "1.0.0",
  "description": "Standalone Oyama Bridge app for local AI gateway and donor/report Steward intelligence routing.",
  "author": "OyamaCRM",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "test": "node --test tests/bridge-server.test.js",
    "build:installer": "npm run build:installer:script",
    "build:installer:nsis:oneclick": "npm run build:installer:script",
    "build:installer:script": "build-nsis-oneclick.bat",
    "installer:nsis:oneclick": "electron-builder --win nsis --publish never",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.oyama.bridge",
    "productName": "Oyama Bridge",
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "files": [
      "main.js",
      "bridge-server.js",
      "gpu-telemetry.js",
      "ollama-runtime.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "styles.css",
      "assets/**/*",
      "package.json",
      "!node_modules/**"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Oyama-Bridge-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "shortcutName": "Oyama Bridge"
    }
  }
}
