{
  "name": "agents-create-oyamam-crm-workspace",
  "version": "0.3.0",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "next dev",
    "dev:web": "next dev",
    "dev:api": "tsx watch server/src/index.ts",
    "dev:all": "node scripts/dev-all-open-cors.mjs",
    "dev:all:strict": "concurrently -k -n api,web -c cyan,green \"pnpm dev:api\" \"pnpm dev:web\"",
    "build": "next build",
    "build:server": "tsc --project server/tsconfig.json",
    "start": "next start",
    "start:server": "node dist/server/index.js",
    "lint": "eslint",
    "typecheck:web": "tsc --noEmit",
    "typecheck:server": "tsc --project server/tsconfig.json --noEmit",
    "typecheck": "pnpm typecheck:web && pnpm typecheck:server",
    "check:all": "pnpm lint && pnpm typecheck",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:api": "vitest run tests/api",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:smoke": "vitest run tests/smoke",
    "test:smoke:routes": "node tests/e2e/routes-smoke.mjs",
    "test:smoke:critical": "vitest run tests/smoke/critical-hardening.test.ts",
    "test:smoke:livecom": "vitest run tests/smoke/livecom-workflow.test.ts",
    "test:e2e": "node tests/e2e/ui-production-smoke.mjs",
    "test:e2e:auth": "node tests/e2e/auth.e2e.mjs",
    "test:e2e:watchdog": "node tests/e2e/watchdog.e2e.mjs",
    "test:e2e:setup-watchdog": "node tests/e2e/setup-watchdog-config.e2e.mjs",
    "test:e2e:mobile": "node tests/e2e/mobile-readiness-audit.mjs",
    "test:e2e:responsive": "node scripts/qa/responsive-ui-pass.mjs",
    "test:e2e:livecom": "node tests/e2e/livecom-ui-smoke.mjs",
    "test:regression": "vitest run tests/regression",
    "test:all": "pnpm test:unit && pnpm test:api && pnpm test:smoke && pnpm test:e2e && pnpm test:e2e:mobile",
    "test:ci": "pnpm lint && pnpm typecheck && pnpm test:unit && pnpm test:api && pnpm test:smoke && pnpm build",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts --size small",
    "db:seed:small": "tsx prisma/seed.ts --size small",
    "db:seed:medium": "tsx prisma/seed.ts --size medium",
    "db:seed:large": "tsx prisma/seed.ts --size large",
    "db:seed:tiny-gifts": "tsx prisma/seed.ts --tiny-gifts",
    "db:verify:tiny-gifts": "tsx prisma/verify-tiny-gifts-seed.ts",
    "db:verify:demo": "tsx prisma/verify-demo-seed.ts",
    "db:verify:linux-casing": "node scripts/verify-linux-migration-casing.mjs",
    "db:reset": "prisma migrate reset --force --skip-generate",
    "db:reset:demo": "prisma migrate reset --force --skip-generate --skip-seed && pnpm db:seed:small && pnpm db:verify:demo",
    "db:reset:tiny-gifts": "prisma migrate reset --force --skip-generate --skip-seed && pnpm db:seed:tiny-gifts && pnpm db:verify:tiny-gifts",
    "db:studio": "prisma studio",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:reload": "pm2 reload ecosystem.config.cjs",
    "pm2:delete": "pm2 delete ecosystem.config.cjs",
    "pm2:logs": "pm2 logs oyama-crm",
    "pm2:status": "pm2 status"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/list": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@prisma/client": "^5.22.0",
    "@tiptap/extension-color": "^3.23.2",
    "@tiptap/extension-image": "^3.23.2",
    "@tiptap/extension-link": "^3.23.2",
    "@tiptap/extension-placeholder": "^3.23.2",
    "@tiptap/extension-table": "^3.23.2",
    "@tiptap/extension-table-cell": "^3.23.2",
    "@tiptap/extension-table-header": "^3.23.2",
    "@tiptap/extension-table-row": "^3.23.2",
    "@tiptap/extension-text-align": "^3.23.2",
    "@tiptap/extension-text-style": "^3.23.2",
    "@tiptap/extension-underline": "^3.23.2",
    "@tiptap/react": "^3.23.2",
    "@tiptap/starter-kit": "^3.23.2",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "intuit-oauth": "^4.2.3",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "next": "16.2.5",
    "nodemailer": "^8.0.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@rolldown/binding-win32-x64-msvc": "^1.0.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^11.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "concurrently": "^9.1.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.5",
    "mysql2": "^3.22.3",
    "playwright": "1.59.1",
    "pm2": "^5",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp"
    ]
  }
}
