    "db:reset:demo": "prisma migrate reset --force --skip-generate --skip-seed && pnpm db:seed:small && pnpm db:verify:demo",
    "db:reset:tiny-gifts": "prisma migrate reset --force --skip-generate --skip-seed && pnpm db:seed:tiny-gifts && pnpm db:verify:tiny-gifts",
