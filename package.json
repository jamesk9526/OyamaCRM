    "pm2:delete": "pm2 delete ecosystem.config.cjs",
    "pm2:logs": "pm2 logs oyama-crm-web oyama-crm-api oyama-letters",
    "pm2:logs:web": "pm2 logs oyama-crm-web",
    "pm2:logs:api": "pm2 logs oyama-crm-api",
    "pm2:logs:letters": "pm2 logs oyama-letters",
