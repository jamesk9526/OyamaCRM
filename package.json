    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "node --import tsx prisma/seed.ts --size small",
    "db:seed:small": "node --import tsx prisma/seed.ts --size small",
    "db:seed:medium": "node --import tsx prisma/seed.ts --size medium",
    "db:seed:large": "node --import tsx prisma/seed.ts --size large",
