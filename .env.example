# OyamaCRM application configuration

# Core database / auth
DATABASE_URL="mysql://user:password@localhost:3306/oyamacrm"
JWT_SECRET="replace-with-a-long-random-secret"
API_PORT=4000
NEXT_PUBLIC_API_URL="http://localhost:4000"

# OyamaPASSWORD secure vault (must be a separate external database)
OYAMA_PASSWORD_DATABASE_URL="mysql://user:password@localhost:3306/oyama_password"
OYAMA_PASSWORD_ENCRYPTION_KEY="replace-with-64-char-hex-or-strong-passphrase"

# Safe version/build metadata shown in Settings and /api/health
APP_NAME="OyamaCRM"
APP_VERSION="0.1.0"
BUILD_DATE="2026-05-08"
GIT_COMMIT="local-dev"
RELEASE_CHANNEL="development"
LAST_AUDIT_DATE="2026-05-08"

# Optional frontend-safe mirrors when you want exact values baked into the Next.js app
NEXT_PUBLIC_APP_NAME="OyamaCRM"
NEXT_PUBLIC_APP_VERSION="0.1.0"
NEXT_PUBLIC_BUILD_DATE="2026-05-08"
NEXT_PUBLIC_GIT_COMMIT="local-dev"
NEXT_PUBLIC_RELEASE_CHANNEL="development"
NEXT_PUBLIC_APP_ENV="development"
NEXT_PUBLIC_LAST_AUDIT_DATE="2026-05-08"
