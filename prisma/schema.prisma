// ─── Plugin System ────────────────────────────────────────────────────────────

/// Status of a single item in the QuickBooks sync queue.
enum QBSyncStatus {
  PENDING // Waiting in queue; not yet sent to QB
  SYNCED // Successfully pushed to QuickBooks
  FAILED // Sync attempted but QB returned an error
  SKIPPED // Manually removed from queue without syncing
}

/// Stores the enabled/disabled state and OAuth tokens for each third-party plugin.
/// One row per plugin per organization. Current plugin keys: "quickbooks"
model PluginSetting {
  id             String   @id @default(cuid())
  organizationId String
  /// Machine key identifying the plugin (e.g. "quickbooks")
  pluginKey      String
  /// Whether this plugin is active for the organization
  enabled        Boolean  @default(false)
  /// JSON blob storing OAuth tokens and plugin-specific config (encrypted at rest by the server layer)
  config         Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, pluginKey])
  @@index([organizationId])
}

/// A single donation queued for syncing to QuickBooks.
/// Only NEW donations (created after plugin is enabled) appear here.
/// Staff review and edit the queue before manually triggering the sync.
model QBSyncQueueItem {
  id             String       @id @default(cuid())
  organizationId String
  /// The donation being synced — null if donation was deleted before sync
  donationId     String?
  status         QBSyncStatus @default(PENDING)

  // Editable snapshot of what will be sent to QB (can be adjusted before syncing)
  /// QB Customer name override (defaults to donor full name)
  customerName String?
  /// QB account/class mapping for this donation
  qbAccount    String?
  /// QB memo line (defaults to campaign + designation info)
  memo         String?
  /// Amount to sync — can differ from donation amount if org wants to override
  amount       Decimal? @db.Decimal(12, 2)

  /// QuickBooks Sales Receipt or Donation ID returned on success
  qbEntityId   String?
  /// Raw error message if sync failed
  errorMessage String?   @db.Text
  /// When this item was successfully synced
  syncedAt     DateTime?
  /// Number of sync attempts made
  attemptCount Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  donation     Donation?    @relation(fields: [donationId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([donationId])
}

enum CompassionAppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
}

enum CompassionServiceType {
  PREGNANCY_TEST
  ULTRASOUND
  DIAPERS
  CLOTHING
  FORMULA
  PARENTING_CLASS
  HOUSING_REFERRAL
  EDUCATION_REFERRAL
  JOB_REFERRAL
  NUTRITION_SUPPORT
  COUNSELING
  TRANSPORTATION_RESOURCE
  OTHER
}

enum CompassionFollowUpStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  OVERDUE
}

enum CompassionPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── Compassion CRM Models ────────────────────────────────────────────────────

/// Staff directory for Compassion CRM assignments. Staff can optionally link to a platform user.
model CompassionStaff {
  id             String  @id @default(cuid())
  organizationId String
  linkedUserId   String? @unique

  firstName          String
  lastName           String
  displayName        String?
  title              String?
  email              String?
  phone              String?
  isActive           Boolean @default(true)
  supportsScheduling Boolean @default(true)
  notes              String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  linkedUser   User?        @relation("CompassionStaffLinkedUser", fields: [linkedUserId], references: [id])

  assignedClients      CompassionClient[]      @relation("CompassionClientCompassionStaff")
  assignedCases        CompassionCase[]        @relation("CompassionCaseCompassionStaff")
  assignedAppointments CompassionAppointment[] @relation("CompassionApptCompassionStaff")
  providedServices     CompassionService[]     @relation("CompassionServiceCompassionStaff")
  assignedFollowUps    CompassionFollowUp[]    @relation("CompassionFollowUpCompassionStaff")
  performedActivities  CompassionActivity[]    @relation("CompassionActivityCompassionStaff")

  @@unique([organizationId, email])
  @@index([organizationId, isActive])
}

/// Client record — Compassion CRM's core entity, separate from DonorCRM Constituent.
/// Sensitive client data must NOT appear in DonorCRM without explicit permission.
model CompassionClient {
  id             String  @id @default(cuid())
  organizationId String
  /// Optional link to shared Constituent identity (explicit staff-set link only)
  constituentId  String?

  firstName     String
  lastName      String
  preferredName String?
  email         String?
  phone         String?
  addressLine1  String?
  addressLine2  String?
  city          String?
  state         String?
  zip           String?
  dateOfBirth   DateTime?

  clientStatus              CompassionClientStatus @default(ACTIVE)
  assignedStaffId           String?
  assignedCompassionStaffId String?
  intakeDate                DateTime               @default(now())
  referralSource            String?
  /// Private notes — must NOT appear in shared timelines or public-facing endpoints
  privateNotes              String?                @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization            Organization            @relation(fields: [organizationId], references: [id])
  constituent             Constituent?            @relation(fields: [constituentId], references: [id])
  assignedStaff           User?                   @relation("CompassionClientStaff", fields: [assignedStaffId], references: [id])
  assignedCompassionStaff CompassionStaff?        @relation("CompassionClientCompassionStaff", fields: [assignedCompassionStaffId], references: [id])
  cases                   CompassionCase[]
  appointments            CompassionAppointment[]
  services                CompassionService[]
  followUps               CompassionFollowUp[]
  activities              CompassionActivity[]
}

/// Case record — tracks a client's service engagement over time.
model CompassionCase {
  id             String @id @default(cuid())
  organizationId String
  clientId       String

  caseNumber                String               @unique
  caseStatus                CompassionCaseStatus @default(OPEN)
  caseType                  CompassionCaseType   @default(OTHER)
  openedAt                  DateTime             @default(now())
  closedAt                  DateTime?
  assignedStaffId           String?
  assignedCompassionStaffId String?
  priority                  CompassionPriority   @default(MEDIUM)
  summary                   String?              @db.Text
  /// Private notes — must NOT appear in shared timelines
  privateNotes              String?              @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization            Organization            @relation(fields: [organizationId], references: [id])
  client                  CompassionClient        @relation(fields: [clientId], references: [id])
  assignedStaff           User?                   @relation("CompassionCaseStaff", fields: [assignedStaffId], references: [id])
  assignedCompassionStaff CompassionStaff?        @relation("CompassionCaseCompassionStaff", fields: [assignedCompassionStaffId], references: [id])
  appointments            CompassionAppointment[]
  services                CompassionService[]
  followUps               CompassionFollowUp[]
  activities              CompassionActivity[]
}

/// Appointment — scheduled meeting between staff and client.
model CompassionAppointment {
  id             String  @id @default(cuid())
  organizationId String
  clientId       String
  caseId         String?

  appointmentType           CompassionAppointmentType   @default(OTHER)
  status                    CompassionAppointmentStatus @default(SCHEDULED)
  startTime                 DateTime
  endTime                   DateTime?
  timezone                  String                      @default("America/Chicago")
  location                  String?
  assignedStaffId           String?
  assignedCompassionStaffId String?
  notes                     String?                     @db.Text
  outcome                   String?                     @db.Text
  followUpNeeded            Boolean                     @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization            Organization         @relation(fields: [organizationId], references: [id])
  client                  CompassionClient     @relation(fields: [clientId], references: [id])
  case                    CompassionCase?      @relation(fields: [caseId], references: [id])
  assignedStaff           User?                @relation("CompassionApptStaff", fields: [assignedStaffId], references: [id])
  assignedCompassionStaff CompassionStaff?     @relation("CompassionApptCompassionStaff", fields: [assignedCompassionStaffId], references: [id])
  followUps               CompassionFollowUp[]
  activities              CompassionActivity[]
}

/// Service — tracks a specific service delivered to a client.
model CompassionService {
  id             String  @id @default(cuid())
  organizationId String
  clientId       String
  caseId         String?

  serviceType                 CompassionServiceType @default(OTHER)
  serviceDate                 DateTime              @default(now())
  quantity                    Int?
  notes                       String?               @db.Text
  providedById                String?
  providedByCompassionStaffId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization              Organization     @relation(fields: [organizationId], references: [id])
  client                    CompassionClient @relation(fields: [clientId], references: [id])
  case                      CompassionCase?  @relation(fields: [caseId], references: [id])
  providedBy                User?            @relation("CompassionServiceProvider", fields: [providedById], references: [id])
  providedByCompassionStaff CompassionStaff? @relation("CompassionServiceCompassionStaff", fields: [providedByCompassionStaffId], references: [id])
}

/// Follow-up — a tracked action item tied to a client or case.
model CompassionFollowUp {
  id             String  @id @default(cuid())
  organizationId String
  clientId       String
  caseId         String?
  appointmentId  String?

  title                     String
  dueDate                   DateTime
  status                    CompassionFollowUpStatus @default(PENDING)
  priority                  CompassionPriority       @default(MEDIUM)
  assignedStaffId           String?
  assignedCompassionStaffId String?
  notes                     String?                  @db.Text
  completedAt               DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization            Organization           @relation(fields: [organizationId], references: [id])
  client                  CompassionClient       @relation(fields: [clientId], references: [id])
  case                    CompassionCase?        @relation(fields: [caseId], references: [id])
  appointment             CompassionAppointment? @relation(fields: [appointmentId], references: [id])
  assignedStaff           User?                  @relation("CompassionFollowUpStaff", fields: [assignedStaffId], references: [id])
  assignedCompassionStaff CompassionStaff?       @relation("CompassionFollowUpCompassionStaff", fields: [assignedCompassionStaffId], references: [id])
}

// ─── CRM Messenger ───────────────────────────────────────────────────────────

/// A direct-message thread between two (or more) staff users within the same org.
model CrmThread {
  id             String   @id @default(cuid())
  organizationId String
  /// Thread display name, set for group threads; null for 1-to-1 DMs.
  name           String?
  /// Type: DIRECT (1-to-1) or GROUP.
  type           String   @default("DIRECT")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id])
  participants CrmThreadParticipant[]
  messages     CrmMessage[]

  @@index([organizationId])
}

/// Represents a user's membership in a CrmThread; tracks their last-read cursor.
model CrmThreadParticipant {
  id           String    @id @default(cuid())
  threadId     String
  userId       String
  /// UTC timestamp of the last message the user has read in this thread.
  lastReadAt   DateTime?
  joinedAt     DateTime  @default(now())

  thread CrmThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User      @relation("CrmThreadParticipantUser", fields: [userId], references: [id])

  @@unique([threadId, userId])
  @@index([userId])
}

/// A single chat message sent in a CrmThread.
model CrmMessage {
  id         String   @id @default(cuid())
  threadId   String
  senderId   String
  /// Message body — supports plain text.
  body       String   @db.Text
  /// Optional soft-delete timestamp.
  deletedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  thread CrmThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User      @relation("CrmMessageSender", fields: [senderId], references: [id])

  @@index([threadId, createdAt])
  @@index([senderId])
}

/// Activity timeline for Compassion CRM events.
model CompassionActivity {
  id             String  @id @default(cuid())
  organizationId String
  clientId       String
  caseId         String?
  appointmentId  String?

  /// Activity type string: CLIENT_CREATED, CASE_OPENED, APPOINTMENT_SCHEDULED, etc.
  activityType                 String
  description                  String  @db.Text
  performedById                String?
  performedByCompassionStaffId String?
  metadata                     Json?

  createdAt DateTime @default(now())

  organization               Organization           @relation(fields: [organizationId], references: [id])
  client                     CompassionClient       @relation(fields: [clientId], references: [id])
  case                       CompassionCase?        @relation(fields: [caseId], references: [id])
  appointment                CompassionAppointment? @relation(fields: [appointmentId], references: [id])
  performedBy                User?                  @relation("CompassionActivityUser", fields: [performedById], references: [id])
  performedByCompassionStaff CompassionStaff?       @relation("CompassionActivityCompassionStaff", fields: [performedByCompassionStaffId], references: [id])
}
