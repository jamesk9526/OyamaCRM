// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum ConstituentType {
  DONOR
  HOUSEHOLD
  VOLUNTEER
  MEMBER
  PROSPECT
  SPONSOR
  BOARD_MEMBER
  FOUNDATION
  ORGANIZATION
}

enum DonorStatus {
  NEW
  ACTIVE
  LAPSED
  MAJOR_DONOR
  DECEASED
}

enum DonationStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CREDIT_CARD
  ACH
  CHECK
  WIRE
  STOCK
  IN_KIND
  CASH
  ONLINE
}

enum RecurringFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskType {
  CALL
  EMAIL
  MAIL
  MEETING
  THANK_YOU
  FOLLOW_UP
  OTHER
}

enum CampaignCategory {
  ANNUAL_FUND
  CAPITAL
  ENDOWMENT
  EVENT
  GIVING_DAY
  MAJOR_GIFTS
  PLANNED_GIVING
  GENERAL
}

enum EventType {
  GALA
  AUCTION
  RUN_WALK
  CONFERENCE
  WORKSHOP
  CULTIVATION
  STEWARDSHIP
  VOLUNTEER
  ONLINE
  OTHER
}

enum EventStatus {
  DRAFT
  PUBLISHED
  REGISTRATION_OPEN
  REGISTRATION_CLOSED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum EventVisibility {
  PUBLIC
  PRIVATE
  INVITE_ONLY
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
}

enum SponsorshipLevel {
  TITLE
  PLATINUM
  GOLD
  SILVER
  BRONZE
  PARTNER
  IN_KIND
}

enum EventGuestPaymentStatus {
  PAID
  DUE
  PENDING_CHECK
  COMP
  SPONSORED
}

enum EventGuestRsvpStatus {
  PENDING
  CONFIRMED
  DECLINED
  WAITLIST
}

enum CommunicationChannel {
  EMAIL
  PHONE
  MAIL
  TEXT
  IN_PERSON
}

enum EmailCampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  CANCELLED
}

enum ActivityType {
  DONATION
  TASK_COMPLETED
  EMAIL_SENT
  EMAIL_RECEIVED
  CALL
  MEETING
  MEETING_SCHEDULED
  MEETING_COMPLETED
  MEETING_CANCELED
  NOTE
  EVENT_REGISTRATION
  EVENT_ATTENDANCE
  VOLUNTEER_HOURS
  PLEDGE_MADE
}

// ─── Meeting Enums ────────────────────────────────────────────────────────────

enum MeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELED
  NO_SHOW
  RESCHEDULED
  NEEDS_FOLLOW_UP
}

enum MeetingType {
  DONOR_VISIT
  PHONE_CALL
  LUNCH_MEETING
  BOARD_MEETING
  SPONSOR_MEETING
  MAJOR_DONOR_MEETING
  CHURCH_PRESENTATION
  VOLUNTEER_MEETING
  FOLLOW_UP_CALL
  THANK_YOU_VISIT
  VIDEO_CALL
  OTHER
}

enum MeetingLocationType {
  IN_PERSON
  PHONE
  VIDEO
  AT_DONORS_HOME
  AT_CHURCH
  AT_OFFICE
  AT_EVENT
  CUSTOM
}

// ─── Core Models ─────────────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  constituents   Constituent[]
  campaigns      Campaign[]
  events         Event[]
  users          User[]
  meetings       Meeting[]
  settings       OrganizationSettings?
  emailCampaigns EmailCampaign[]
  customFields   CustomField[]
  grantFunders   GrantFunder[]
  grants         Grant[]
}

model OrganizationSettings {
  id              String   @id @default(cuid())
  organizationId  String   @unique
  fiscalYearStart Int      @default(1) // Month 1-12
  currency        String   @default("USD")
  timezone        String   @default("America/Chicago")
  smtpHost        String?
  smtpPort        Int?
  smtpSecure      Boolean  @default(true)
  smtpUser        String?
  smtpPass        String?
  smtpFromName    String?
  smtpFromEmail   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
}

model User {
  id             String    @id @default(cuid())
  organizationId String
  email          String    @unique
  firstName      String
  lastName       String
  role           String    @default("staff") // admin | manager | staff | readonly | report_viewer
  avatarUrl      String?
  active         Boolean   @default(true)
  passwordHash   String?
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id])
  assignedTasks   Task[]           @relation("TaskAssignee")
  createdTasks    Task[]           @relation("TaskCreator")
  assignedMeetings Meeting[]       @relation("MeetingAssignee")
  createdMeetings  Meeting[]       @relation("MeetingCreator")
  activities      Activity[]
  refreshTokens   RefreshToken[]
  auditLogs       AuditLog[]
  permissions     UserPermission[]
  assignedGrants  Grant[]          @relation("GrantAssignee")
  grantActivities GrantActivity[]
  ownedEvents     Event[]
}

// ─── Constituent (Donor/Volunteer/Member) ─────────────────────────────────────

model Constituent {
  id             String          @id @default(cuid())
  organizationId String
  type           ConstituentType @default(DONOR)
  donorStatus    DonorStatus     @default(NEW)

  // Contact info
  prefix    String?
  firstName String
  lastName  String
  email     String?
  email2    String?
  phone     String?
  phone2    String?
  mobile    String?

  // Address
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  zip          String?
  country      String  @default("US")

  // Profile
  birthDate  DateTime?
  employer   String?
  occupation String?
  notes      String?   @db.Text
  avatarUrl  String?
  externalId String?   @db.VarChar(100) // Source system ID (e.g. DirID from eKYROS) for dedup on re-import

  // Household
  householdId      String?
  isPrimaryContact Boolean @default(true)

  // Communication preferences
  doNotEmail   Boolean @default(false)
  doNotCall    Boolean @default(false)
  doNotMail    Boolean @default(false)
  doNotContact Boolean @default(false)
  emailOptOut  Boolean @default(false)

  // Giving summary (denormalized for performance)
  totalLifetimeGiving Decimal   @default(0) @db.Decimal(12, 2)
  totalYtdGiving      Decimal   @default(0) @db.Decimal(12, 2)
  firstGiftDate       DateTime?
  lastGiftDate        DateTime?
  lastGiftAmount      Decimal?  @db.Decimal(10, 2)
  giftCount           Int       @default(0)
  engagementScore     Int       @default(0) // 0-100

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id])
  household        Household?        @relation("HouseholdMembers", fields: [householdId], references: [id])
  headOf           Household?        @relation("HouseholdHead")
  donations        Donation[]
  tasks            Task[]
  meetings         Meeting[]
  tags             ConstituentTag[]
  activities       Activity[]
  eventAttendances EventAttendance[]
  eventOrders      EventOrder[]
  eventGuests      EventGuest[]
  eventSponsors    EventSponsor[]
  volunteerHours   VolunteerHour[]
  pledges          Pledge[]
}

model Household {
  id                String   @id @default(cuid())
  name              String
  headConstituentId String?  @unique
  addressLine1      String?
  addressLine2      String?
  city              String?
  state             String?
  zip               String?
  country           String   @default("US")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  head    Constituent?  @relation("HouseholdHead", fields: [headConstituentId], references: [id])
  members Constituent[] @relation("HouseholdMembers")
}

model Tag {
  id          String   @id @default(cuid())
  name        String
  color       String   @default("#16a34a")
  description String?
  createdAt   DateTime @default(now())

  constituents ConstituentTag[]
}

model ConstituentTag {
  constituentId String
  tagId         String
  createdAt     DateTime @default(now())

  constituent Constituent @relation(fields: [constituentId], references: [id], onDelete: Cascade)
  tag         Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([constituentId, tagId])
}

// ─── Donations & Pledges ─────────────────────────────────────────────────────

model Donation {
  id            String  @id @default(cuid())
  constituentId String
  campaignId    String?
  designationId String?
  pledgeId      String?
  eventId       String?

  amount        Decimal        @db.Decimal(10, 2)
  feeAmount     Decimal        @default(0) @db.Decimal(8, 2)
  date          DateTime       @default(now())
  paymentMethod PaymentMethod  @default(ONLINE)
  status        DonationStatus @default(COMPLETED)
  checkNumber   String?
  transactionId String?

  isRecurring  Boolean             @default(false)
  frequency    RecurringFrequency?
  nextGiftDate DateTime?

  receiptNumber        String?   @unique
  receiptSentAt        DateTime?
  acknowledgmentSentAt DateTime?
  taxDeductible        Boolean   @default(true)

  inKindDescription String?
  notes             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  constituent Constituent  @relation(fields: [constituentId], references: [id])
  campaign    Campaign?    @relation(fields: [campaignId], references: [id])
  designation Designation? @relation(fields: [designationId], references: [id])
  pledge      Pledge?      @relation(fields: [pledgeId], references: [id])
  event       Event?       @relation(fields: [eventId], references: [id])
  activities  Activity[]
}

model Pledge {
  id            String  @id @default(cuid())
  constituentId String
  campaignId    String?
  designationId String?

  totalAmount Decimal             @db.Decimal(10, 2)
  paidAmount  Decimal             @default(0) @db.Decimal(10, 2)
  startDate   DateTime
  endDate     DateTime?
  frequency   RecurringFrequency?
  notes       String?
  active      Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  constituent Constituent  @relation(fields: [constituentId], references: [id])
  campaign    Campaign?    @relation(fields: [campaignId], references: [id])
  designation Designation? @relation(fields: [designationId], references: [id])
  payments    Donation[]
}

model Designation {
  id          String   @id @default(cuid())
  name        String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  donations Donation[]
  pledges   Pledge[]
}

// ─── Campaigns ───────────────────────────────────────────────────────────────

model Campaign {
  id             String           @id @default(cuid())
  organizationId String
  name           String
  description    String?          @db.Text
  category       CampaignCategory @default(ANNUAL_FUND)
  goal           Decimal?         @db.Decimal(12, 2)
  startDate      DateTime
  endDate        DateTime?
  active         Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  donations    Donation[]
  pledges      Pledge[]
}

// ─── Tasks ───────────────────────────────────────────────────────────────────

model Task {
  id            String  @id @default(cuid())
  constituentId String?
  assigneeId    String?
  createdById   String?

  title       String
  description String?      @db.Text
  type        TaskType     @default(FOLLOW_UP)
  status      TaskStatus   @default(PENDING)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  constituent Constituent? @relation(fields: [constituentId], references: [id])
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdBy   User?        @relation("TaskCreator", fields: [createdById], references: [id])
  activities  Activity[]
  meeting     Meeting?     @relation(fields: [meetingId], references: [id])
  meetingId   String?
}

// ─── Meetings ─────────────────────────────────────────────────────────────────

model Meeting {
  id             String @id @default(cuid())
  organizationId String

  title   String
  type    MeetingType         @default(OTHER)
  status  MeetingStatus       @default(SCHEDULED)

  startTime DateTime
  endTime   DateTime?
  timezone  String            @default("America/Chicago")

  locationType MeetingLocationType @default(IN_PERSON)
  location     String?
  meetingUrl   String?

  purpose      String?  @db.Text
  notes        String?  @db.Text
  privateNotes String?  @db.Text
  outcome      String?  @db.Text

  followUpNeeded Boolean @default(false)

  // Relations
  constituentId  String?
  assignedStaffId String?
  createdById    String?

  completedAt DateTime?
  canceledAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])
  constituent    Constituent? @relation(fields: [constituentId], references: [id])
  assignedStaff  User?        @relation("MeetingAssignee", fields: [assignedStaffId], references: [id])
  createdBy      User?        @relation("MeetingCreator", fields: [createdById], references: [id])
  tasks          Task[]
  activities     Activity[]
}

// ─── Events ──────────────────────────────────────────────────────────────────

model Event {
  id             String          @id @default(cuid())
  organizationId String
  name           String
  description    String?         @db.Text
  type           EventType       @default(OTHER)
  status         EventStatus     @default(DRAFT)
  visibility     EventVisibility @default(PUBLIC)

  // Location details
  location   String?
  address    String?
  city       String?
  state      String?
  zip        String?
  virtualUrl String?

  // Date & time
  startDate            DateTime
  endDate              DateTime?
  registrationDeadline DateTime?

  // Capacity & goals
  capacity         Int?
  registrationGoal Int?
  revenueGoal      Decimal? @db.Decimal(10, 2)

  // Ownership & management
  ownerId       String?
  internalNotes String? @db.Text

  // Legacy active field (consider deprecating in favor of status)
  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization   Organization      @relation(fields: [organizationId], references: [id])
  owner          User?             @relation(fields: [ownerId], references: [id])
  ticketTypes    TicketType[]
  orders         EventOrder[]
  guests         EventGuest[]
  tables         EventTable[]
  sponsors       EventSponsor[]
  donations      Donation[]
  activities     Activity[]
  volunteerHours VolunteerHour[]
  // Legacy - kept for backward compatibility during migration
  attendances    EventAttendance[]
}

model TicketType {
  id          String   @id @default(cuid())
  eventId     String
  name        String
  description String?  @db.Text
  price       Decimal  @db.Decimal(8, 2)
  capacity    Int?
  available   Int?
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  // Table ticket support (from GalaSoft concepts)
  isTable       Boolean @default(false)
  seatsIncluded Int     @default(1)
  minPerOrder   Int     @default(1)
  maxPerOrder   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event      Event            @relation(fields: [eventId], references: [id])
  orderItems EventOrderItem[]
  guests     EventGuest[]
}

model EventOrder {
  id            String      @id @default(cuid())
  eventId       String
  constituentId String
  orderNumber   String      @unique
  status        OrderStatus @default(PENDING)

  totalAmount Decimal @db.Decimal(10, 2)
  feeAmount   Decimal @default(0) @db.Decimal(8, 2)

  paymentMethod PaymentMethod?
  transactionId String?
  paidAt        DateTime?

  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event       Event            @relation(fields: [eventId], references: [id])
  constituent Constituent      @relation(fields: [constituentId], references: [id])
  items       EventOrderItem[]
  guests      EventGuest[]
}

model EventOrderItem {
  id           String   @id @default(cuid())
  orderId      String
  ticketTypeId String
  quantity     Int      @default(1)
  unitPrice    Decimal  @db.Decimal(8, 2)
  totalPrice   Decimal  @db.Decimal(8, 2)
  createdAt    DateTime @default(now())

  order      EventOrder @relation(fields: [orderId], references: [id])
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])
}

model EventGuest {
  id            String  @id @default(cuid())
  eventId       String
  orderId       String?
  constituentId String?
  ticketTypeId  String?
  tableId       String?

  // Guest details (can be independent of constituent)
  firstName String?
  lastName  String?
  email     String?
  phone     String?

  // Check-in
  checkedIn   Boolean   @default(false)
  checkedInAt DateTime?
  checkinCode String?   @unique

  // Registration status fields (from GalaSoft concepts)
  paymentStatus  EventGuestPaymentStatus @default(DUE)
  rsvpStatus     EventGuestRsvpStatus    @default(PENDING)
  mealPreference String?
  seatNumber     Int?
  partyName      String?

  // Dietary & accessibility
  dietaryRestrictions String?
  specialNeeds        String?
  notes               String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event       Event        @relation(fields: [eventId], references: [id])
  order       EventOrder?  @relation(fields: [orderId], references: [id])
  constituent Constituent? @relation(fields: [constituentId], references: [id])
  ticketType  TicketType?  @relation(fields: [ticketTypeId], references: [id])
  table       EventTable?  @relation(fields: [tableId], references: [id])
}

model EventTable {
  id        String   @id @default(cuid())
  eventId   String
  name      String
  capacity  Int      @default(10)
  notes     String?  @db.Text
  // Seating layout fields (from GalaSoft concepts)
  tableNumber Int?
  isSponsored Boolean @default(false)
  hostName    String?
  xPosition   Int     @default(0)
  yPosition   Int     @default(0)
  shape       String  @default("round")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event  Event        @relation(fields: [eventId], references: [id])
  guests EventGuest[]
}

model EventSponsor {
  id            String           @id @default(cuid())
  eventId       String
  constituentId String
  level         SponsorshipLevel
  amount        Decimal          @db.Decimal(10, 2)
  benefits      String?          @db.Text
  logoUrl       String?
  websiteUrl    String?
  notes         String?          @db.Text
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  event       Event       @relation(fields: [eventId], references: [id])
  constituent Constituent @relation(fields: [constituentId], references: [id])
}

// Legacy EventAttendance - kept for backward compatibility during migration
// TODO: Migrate data to EventGuest and deprecate
model EventAttendance {
  id            String    @id @default(cuid())
  eventId       String
  constituentId String
  checkedIn     Boolean   @default(false)
  checkedInAt   DateTime?
  ticketType    String?
  amountPaid    Decimal?  @db.Decimal(8, 2)
  createdAt     DateTime  @default(now())

  event       Event       @relation(fields: [eventId], references: [id])
  constituent Constituent @relation(fields: [constituentId], references: [id])
}

// ─── Volunteers ──────────────────────────────────────────────────────────────

model VolunteerHour {
  id            String   @id @default(cuid())
  constituentId String
  eventId       String?
  hours         Decimal  @db.Decimal(6, 2)
  description   String?
  date          DateTime
  createdAt     DateTime @default(now())

  constituent Constituent @relation(fields: [constituentId], references: [id])
  event       Event?      @relation(fields: [eventId], references: [id])
}

// ─── Activity Timeline ────────────────────────────────────────────────────────

model Activity {
  id            String  @id @default(cuid())
  constituentId String?
  donationId    String?
  taskId        String?
  meetingId     String?
  userId        String?
  eventId       String?

  type        ActivityType
  description String       @db.Text
  metadata    Json?
  createdAt   DateTime     @default(now())

  constituent Constituent? @relation(fields: [constituentId], references: [id])
  donation    Donation?    @relation(fields: [donationId], references: [id])
  task        Task?        @relation(fields: [taskId], references: [id])
  meeting     Meeting?     @relation(fields: [meetingId], references: [id])
  user        User?        @relation(fields: [userId], references: [id])
  event       Event?       @relation(fields: [eventId], references: [id])
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique @db.VarChar(512)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String?
  userId         String?
  action         String // CREATE, UPDATE, DELETE, LOGIN, LOGOUT, etc.
  entity         String? // Constituent, Donation, User, etc.
  entityId       String?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

enum AutomationTrigger {
  DONATION_RECEIVED
  CONSTITUENT_CREATED
  TASK_DUE
  PLEDGE_CREATED
  EMAIL_OPENED
  EVENT_REGISTERED
}

enum AutomationActionType {
  SEND_EMAIL
  CREATE_TASK
  UPDATE_FIELD
  ADD_TAG
  REMOVE_TAG
  ASSIGN_USER
}

// ─── Automations ─────────────────────────────────────────────────────────────

// A saved automation workflow: trigger → conditions → ordered list of actions.
model Automation {
  id             String            @id @default(cuid())
  organizationId String
  name           String
  description    String?
  trigger        AutomationTrigger
  triggerConfig  Json? // Optional filter conditions on the trigger event
  enabled        Boolean           @default(true)
  runCount       Int               @default(0)
  lastRunAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  actions AutomationAction[]
}

// A single action step within an automation workflow.
model AutomationAction {
  id           String               @id @default(cuid())
  automationId String
  type         AutomationActionType
  config       Json? // Action-specific config (e.g. email template ID, tag name)
  order        Int                  @default(0)
  createdAt    DateTime             @default(now())

  automation Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
}

// ─── Email Campaigns(Communications Hub) ─────────────────────────────────────

model EmailCampaign {
  id             String              @id @default(cuid())
  organizationId String
  name           String
  subject        String
  previewText    String?
  fromName       String              @default("OyamaCRM")
  fromEmail      String              @default("noreply@oyamacrm.org")
  replyToEmail   String?
  bodyHtml       String?             @db.LongText
  bodyText       String?             @db.Text
  templateJson   String?             @db.LongText
  status         EmailCampaignStatus @default(DRAFT)
  scheduledAt    DateTime?
  sentAt         DateTime?
  audienceFilter String?             @db.Text // JSON: { type, donorStatus, tags, etc. }

  // Post-send stats
  totalRecipients Int @default(0)
  delivered       Int @default(0)
  opened          Int @default(0)
  clicked         Int @default(0)
  bounced         Int @default(0)
  unsubscribed    Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
}

// ─── Custom Fields ────────────────────────────────────────────────────────────

// CustomField: organization-defined fields extending the built-in data model.
// Supports text, number, boolean, date, select, and multiselect field types.
// Values are stored separately in CustomFieldValue per entity instance.
model CustomField {
  id             String @id @default(cuid())
  organizationId String

  /// Which entity this field belongs to: "constituent" | "donation" | "campaign" | "event"
  entityType   String
  /// Human-readable label shown in the UI
  name         String
  /// Camelcase key used in API payloads (must be unique per org + entityType)
  key          String
  /// One of: text | number | boolean | date | select | multiselect | url | email | phone | textarea
  fieldType    String
  /// JSON-encoded string[] of allowed values (for select / multiselect)
  options      String?  @db.Text
  required     Boolean  @default(false)
  description  String?
  placeholder  String?
  defaultValue String?
  sortOrder    Int      @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id])
  values       CustomFieldValue[]

  @@unique([organizationId, entityType, key])
  @@index([organizationId, entityType])
}

// CustomFieldValue: stores the actual value of a custom field for a specific entity instance.
// entityId points to a constituent ID, donation ID, campaign ID, etc.
// value is JSON-encoded (handles strings, numbers, booleans, dates, arrays).
model CustomFieldValue {
  id         String   @id @default(cuid())
  fieldId    String
  /// ID of the entity (constituentId, donationId, campaignId, etc.)
  entityId   String
  /// Mirrors CustomField.entityType for efficient queries without a join
  entityType String
  /// JSON-encoded value (string, number, boolean, date ISO string, or string[] for multiselect)
  value      String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  field CustomField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([fieldId, entityId])
  @@index([entityId, entityType])
}

// ─── Fine-grained Permissions ─────────────────────────────────────────────────

// UserPermission: per-user feature flags that refine the role-based access defaults.
// A missing row means the role default applies.
// granted=true grants access even if the role would normally deny.
// granted=false explicitly denies access even if the role would normally allow.
model UserPermission {
  id         String   @id @default(cuid())
  userId     String
  // Feature key, e.g. "view:constituents", "edit:donations", "import:data"
  permission String
  // true = explicitly granted, false = explicitly denied
  granted    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permission])
  @@index([userId])
}

// ─── Setup Snapshots (Recovery) ───────────────────────────────────────────────

// SetupSnapshot: serialized backup of org data created before a reset.
// Allows admins to restore the CRM to a known-good state after an accidental wipe.
model SetupSnapshot {
  id           String    @id @default(cuid())
  // Short description shown in the recovery UI
  label        String
  // JSON blob: { organization, settings, users[] } snapshot
  snapshotData String    @db.LongText
  createdAt    DateTime  @default(now())
  // When this snapshot was last restored (null = never restored)
  restoredAt   DateTime?
}

// ─── Grant Management ─────────────────────────────────────────────────────────

/// Current stage of a grant application in the pipeline.
enum GrantStatus {
  IDEA // Initial idea / not yet researched
  RESEARCH // Researching funder requirements
  LOI_DRAFT // Drafting letter of intent
  LOI_SUBMITTED // LOI sent to funder
  PROPOSAL_DRAFT // Writing the full proposal
  PROPOSAL_SUBMITTED // Full proposal submitted
  UNDER_REVIEW // Funder is reviewing the proposal
  AWARDED // Grant awarded!
  REJECTED // Grant denied
  WITHDRAWN // Application withdrawn by us
  CLOSED // Closed for any other reason
}

/// Category of the grant-making organization.
enum GrantFunderType {
  GOVERNMENT
  PRIVATE_FOUNDATION
  CORPORATE
  COMMUNITY
  FAITH_BASED
  INDIVIDUAL
  OTHER
}

/// Type of activity recorded on a grant's timeline.
enum GrantActivityType {
  NOTE
  STATUS_CHANGE
  LOI_SUBMITTED
  PROPOSAL_SUBMITTED
  AWARD_NOTIFICATION
  REJECTION_NOTIFICATION
  REPORTING_SUBMITTED
  DOCUMENT_ADDED
  OTHER
}

/// A grant-making organization (foundation, government agency, corporate, etc.)
model GrantFunder {
  id             String          @id @default(cuid())
  organizationId String
  name           String
  type           GrantFunderType @default(PRIVATE_FOUNDATION)
  website        String?
  contactName    String?
  contactEmail   String?
  contactPhone   String?
  address        String?
  /// Research notes, relationship history, giving interests.
  notes          String?         @db.Text
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  grants       Grant[]
}

/// A single grant opportunity tracked through the application pipeline.
model Grant {
  id             String  @id @default(cuid())
  organizationId String
  funderId       String
  /// Staff member responsible for writing / managing this grant.
  assigneeId     String?

  /// Name of the grant program or opportunity.
  title       String
  /// Program area / focus area (e.g., Youth Services, Housing, Education).
  programArea String?
  status      GrantStatus @default(IDEA)

  amountRequested Decimal? @db.Decimal(12, 2)
  amountAwarded   Decimal? @db.Decimal(12, 2)

  /// Whether this funder requires a letter of intent before the full proposal.
  requiresLOI    Boolean   @default(false)
  loiDeadline    DateTime?
  loiSubmittedAt DateTime?

  applicationDeadline DateTime?
  submittedAt         DateTime?
  awardedAt           DateTime?
  rejectedAt          DateTime?

  /// Grant period start (when funded work begins).
  grantPeriodStart DateTime?
  /// Grant period end (when funded work must be completed).
  grantPeriodEnd   DateTime?

  /// Next reporting deadline (for awarded grants).
  reportingDeadline    DateTime?
  reportingSubmittedAt DateTime?

  notes         String? @db.Text
  internalNotes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id])
  funder       GrantFunder     @relation(fields: [funderId], references: [id])
  assignee     User?           @relation("GrantAssignee", fields: [assigneeId], references: [id])
  sections     GrantSection[]
  activities   GrantActivity[]
}

/// A single writing section within a grant proposal (e.g., need statement, budget narrative).
model GrantSection {
  id        String   @id @default(cuid())
  grantId   String
  /// Machine key for the section (e.g., "executive_summary", "need_statement").
  key       String
  /// Human-readable section title.
  title     String
  content   String?  @db.LongText
  /// Optional word count guidance from the funder.
  wordLimit Int?
  sortOrder Int      @default(0)
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  grant Grant @relation(fields: [grantId], references: [id], onDelete: Cascade)

  @@unique([grantId, key])
}

/// A timeline event or note recorded against a grant.
model GrantActivity {
  id          String            @id @default(cuid())
  grantId     String
  userId      String?
  type        GrantActivityType @default(NOTE)
  description String            @db.Text
  metadata    Json?
  createdAt   DateTime          @default(now())

  grant Grant @relation(fields: [grantId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}
