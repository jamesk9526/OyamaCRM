// ─── Automations ─────────────────────────────────────────────────────────────

// A saved automation workflow: trigger → conditions → ordered list of actions.
model Automation {
  id             String            @id @default(cuid())
  organizationId String
  name           String
  description    String?
  trigger        AutomationTrigger
  triggerConfig  Json? // Optional filter conditions on the trigger event
  enabled        Boolean           @default(true)
  runCount       Int               @default(0)
  lastRunAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  actions AutomationAction[]
}

// A single action step within an automation workflow.
model AutomationAction {
  id           String               @id @default(cuid())
  automationId String
  type         AutomationActionType
  config       Json? // Action-specific config (e.g. email template ID, tag name)
  order        Int                  @default(0)
  createdAt    DateTime             @default(now())

  automation Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
}

// ─── Steward Paths Engagement Sequences ─────────────────────────────────────

model StewardPath {
  id               String             @id @default(cuid())
  organizationId   String
  name             String
  description      String?            @db.Text
  crmScope         StewardPathCrmScope @default(DONOR)
  targetType       StewardPathTarget
  triggerType      String             @default("MANUAL")
  triggerConfig    Json?
  status           StewardPathStatus  @default(DRAFT)
  defaultOwnerId   String?
  createdByUserId  String
  lastEditedByUserId String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  defaultOwner     User?              @relation("StewardPathDefaultOwner", fields: [defaultOwnerId], references: [id], onDelete: SetNull)
  createdBy        User               @relation("StewardPathCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  lastEditedBy     User?              @relation("StewardPathEditedBy", fields: [lastEditedByUserId], references: [id], onDelete: SetNull)
  steps            StewardPathStep[]
  enrollments      StewardPathEnrollment[]

  @@index([organizationId, status])
  @@index([organizationId, crmScope, targetType])
}

model StewardPathStep {
  id            String             @id @default(cuid())
  pathId        String
  orderIndex    Int
  name          String
  description   String?            @db.Text
  stepType      StewardPathStepType
  configJson    Json?
  isRequired    Boolean            @default(true)
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  path          StewardPath        @relation(fields: [pathId], references: [id], onDelete: Cascade)
  runs          StewardPathStepRun[]
  timelineEvents StewardPathTimelineEvent[]
  emailDrafts   StewardPathEmailDraft[]
  enrollmentsAsCurrent StewardPathEnrollment[] @relation("StewardPathCurrentStep")

  @@unique([pathId, orderIndex])
  @@index([pathId, isActive, orderIndex])
}

model StewardPathEnrollment {
  id                  String                       @id @default(cuid())
  organizationId      String
  pathId              String
  targetType          StewardPathTarget
  targetId            String
  constituentId       String?
  status              StewardPathEnrollmentStatus @default(ACTIVE)
  currentStepId       String?
  ownerUserId         String?
  startedAt           DateTime                     @default(now())
  lastStepCompletedAt DateTime?
  nextStepDueAt       DateTime?
  completedAt         DateTime?
  pausedAt            DateTime?
  pausedReason        String?                      @db.Text
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt

  organization        Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  path                StewardPath                  @relation(fields: [pathId], references: [id], onDelete: Cascade)
  currentStep         StewardPathStep?             @relation("StewardPathCurrentStep", fields: [currentStepId], references: [id], onDelete: SetNull)
  ownerUser           User?                        @relation("StewardPathEnrollmentOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  constituent         Constituent?                 @relation(fields: [constituentId], references: [id], onDelete: SetNull)
  stepRuns            StewardPathStepRun[]
  timelineEvents      StewardPathTimelineEvent[]
  emailDrafts         StewardPathEmailDraft[]

  @@index([organizationId, status, nextStepDueAt])
  @@index([pathId, status])
  @@index([targetType, targetId])
  @@index([constituentId])
}

model StewardPathStepRun {
  id            String                   @id @default(cuid())
  enrollmentId  String
  stepId        String
  status        StewardPathStepRunStatus @default(PENDING)
  scheduledFor  DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  resultJson    Json?
  errorMessage  String?                  @db.Text
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  enrollment    StewardPathEnrollment    @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  step          StewardPathStep          @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, stepId])
  @@index([status, scheduledFor])
}

model StewardPathTimelineEvent {
  id              String                      @id @default(cuid())
  enrollmentId    String
  stepId          String?
  eventType       StewardPathTimelineEventType
  message         String                      @db.Text
  metadataJson    Json?
  createdByUserId String?
  createdAt       DateTime                    @default(now())

  enrollment      StewardPathEnrollment       @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  step            StewardPathStep?            @relation(fields: [stepId], references: [id], onDelete: SetNull)
  createdBy       User?                       @relation("StewardPathTimelineCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([enrollmentId, createdAt])
  @@index([eventType, createdAt])
}

model StewardPathEmailDraft {
  id                 String                   @id @default(cuid())
  enrollmentId       String
  stepId             String
  constituentId      String?
  reviewerUserId     String?
  status             StewardPathEmailDraftStatus @default(DRAFT_CREATED)
  subject            String
  body               String                   @db.Text
  fromMode           String                   @default("organization")
  replyToMode        String?
  requireApproval    Boolean                  @default(true)
  allowUserEdits     Boolean                  @default(true)
  sentAt             DateTime?
  skippedAt          DateTime?
  failedAt           DateTime?
  failureReason      String?                  @db.Text
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  enrollment         StewardPathEnrollment    @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  step               StewardPathStep          @relation(fields: [stepId], references: [id], onDelete: Cascade)
  constituent        Constituent?             @relation(fields: [constituentId], references: [id], onDelete: SetNull)
  reviewer           User?                    @relation("StewardPathEmailDraftReviewer", fields: [reviewerUserId], references: [id], onDelete: SetNull)

  @@index([reviewerUserId, status])
  @@index([enrollmentId, status])
}

