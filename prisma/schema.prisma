// ─── Core Models ─────────────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  constituents   Constituent[]
  constituentGroups ConstituentGroup[]
  campaigns      Campaign[]
  events         Event[]
  users          User[]
  meetings       Meeting[]
  tasks          Task[]
  settings       OrganizationSettings?
  emailCampaigns EmailCampaign[]
  customFields   CustomField[]
  grantFunders   GrantFunder[]
  grants         Grant[]
  webmasterSites WebmasterSite[]
  webmasterPages WebmasterPage[]

  // ─── Compassion CRM back-relations ───────────────────────────────────────
  compassionClients      CompassionClient[]
  compassionStaff        CompassionStaff[]
  compassionCases        CompassionCase[]
  compassionAppointments CompassionAppointment[]
  compassionServices     CompassionService[]
  compassionFollowUps    CompassionFollowUp[]
  compassionActivities   CompassionActivity[]

  // ─── Plugin / Integration back-relations ────────────────────────────────
  pluginSettings      PluginSetting[]
  crmThreads          CrmThread[]
  qbSyncQueueItems    QBSyncQueueItem[]
  emailRecipientLists EmailRecipientList[]
  emailDeliveryEvents EmailCampaignDeliveryEvent[]
  emailSubscriptions EmailSubscription[]
  emailPreferences EmailPreference[]
  emailSuppressions EmailSuppression[]
  emailConsentEvents EmailConsentEvent[]
  emailUnsubscribeTokens EmailUnsubscribeToken[]
  emailSendRecipients EmailSendRecipient[]
  emailStatusEvents EmailDeliveryEvent[]
  hrmLocations        HrmLocation[]
  hrmMessages         HrmMessage[]
  hrmSettings         HrmSetting?

  // ─── Steward Paths (engagement sequences) ───────────────────────────────
  stewardPaths           StewardPath[]
  stewardPathEnrollments StewardPathEnrollment[]

  // ─── Donor CRM Letters & Printables back-relations ─────────────────────
  letterHeaderPresets  LetterHeaderPreset[]
  letterFooterPresets  LetterFooterPreset[]
  letterSignatureBlocks LetterSignatureBlock[]
  letterTemplates      LetterTemplate[]
  generatedLetters     GeneratedLetter[]
  notifications        Notification[]
  taskTemplatePresets  TaskTemplatePreset[]
  aiMemoryPreferences  AiMemoryPreference[]
  aiUserMemories       AiUserMemory[]
  aiContextFiles       AiContextFile[]
  aiContextChunks      AiContextChunk[]
}

model OrganizationSettings {
  id                         String   @id @default(cuid())
  organizationId             String   @unique
  fiscalYearStart            Int      @default(1) // Month 1-12
  currency                   String   @default("USD")
  timezone                   String   @default("America/Chicago")
  donorWorkspaceEnabled      Boolean  @default(true)
  compassionWorkspaceEnabled Boolean  @default(true)
  lettersVisualBuilderEnabled Boolean @default(false)
  showModuleSwitcher         Boolean  @default(true)
  defaultWorkspace           String   @default("donor")
  smtpHost                   String?
  smtpPort                   Int?
  smtpSecure                 Boolean  @default(true)
  smtpUser                   String?
  smtpPass                   String?
  smtpFromName               String?
  smtpFromEmail              String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
}

model User {
  id             String    @id @default(cuid())
  organizationId String
  email          String    @unique
  firstName      String
  lastName       String
  role           String    @default("staff") // admin | manager | staff | readonly | report_viewer
  avatarUrl      String?
  active         Boolean   @default(true)
  passwordHash   String?
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization     Organization     @relation(fields: [organizationId], references: [id])
  assignedTasks    Task[]           @relation("TaskAssignee")
  createdTasks     Task[]           @relation("TaskCreator")
  completedTasks   Task[]           @relation("TaskCompletedBy")
  notifications    Notification[]   @relation("NotificationUser")
  assignedMeetings Meeting[]        @relation("MeetingAssignee")
  createdMeetings  Meeting[]        @relation("MeetingCreator")
  activities       Activity[]
  refreshTokens    RefreshToken[]
  auditLogs        AuditLog[]
  permissions      UserPermission[]
  assignedGrants   Grant[]          @relation("GrantAssignee")
  grantActivities  GrantActivity[]
  ownedEvents      Event[]

  // ─── Compassion CRM staff relations ──────────────────────────────────────
  compassionClientsAssigned     CompassionClient[]      @relation("CompassionClientStaff")
  compassionCasesAssigned       CompassionCase[]        @relation("CompassionCaseStaff")
  compassionApptsAssigned       CompassionAppointment[] @relation("CompassionApptStaff")
  compassionServicesProvided    CompassionService[]     @relation("CompassionServiceProvider")
  compassionFollowUpsAssigned   CompassionFollowUp[]    @relation("CompassionFollowUpStaff")
  compassionActivitiesPerformed CompassionActivity[]    @relation("CompassionActivityUser")
  linkedCompassionStaff         CompassionStaff?        @relation("CompassionStaffLinkedUser")
  emailRecipientListsCreated    EmailRecipientList[]    @relation("EmailRecipientListCreator")
  webmasterSitesCreated         WebmasterSite[]         @relation("WebmasterSiteCreator")
  webmasterPagesCreated         WebmasterPage[]         @relation("WebmasterPageCreator")
  webmasterPagesUpdated         WebmasterPage[]         @relation("WebmasterPageUpdater")
  submittedFeedbackTickets      WatchdogFeedbackTicket[] @relation("FeedbackSubmittedBy")
  assignedFeedbackTickets       WatchdogFeedbackTicket[] @relation("FeedbackAssignedDeveloper")
  sentHrmMessages               HrmMessage[]            @relation("HrmMessageSender")
  receivedHrmMessages           HrmMessage[]            @relation("HrmMessageRecipient")
  crmThreadParticipations       CrmThreadParticipant[]  @relation("CrmThreadParticipantUser")
  crmMessagesSent               CrmMessage[]            @relation("CrmMessageSender")

  // ─── Steward Paths ownership/review relations ───────────────────────────
  stewardPathsCreated        StewardPath[]            @relation("StewardPathCreatedBy")
  stewardPathsEdited         StewardPath[]            @relation("StewardPathEditedBy")
  stewardPathsDefaultOwned   StewardPath[]            @relation("StewardPathDefaultOwner")
  stewardPathEnrollmentsOwned StewardPathEnrollment[] @relation("StewardPathEnrollmentOwner")
  stewardPathTimelineEvents  StewardPathTimelineEvent[] @relation("StewardPathTimelineCreatedBy")
  stewardPathEmailDraftsReviewed StewardPathEmailDraft[] @relation("StewardPathEmailDraftReviewer")

  // ─── Donor CRM Letters & Printables relations ──────────────────────────
  letterTemplatesCreated LetterTemplate[] @relation("LetterTemplateCreatedBy")
  letterTemplatesUpdated LetterTemplate[] @relation("LetterTemplateUpdatedBy")
  generatedLetters       GeneratedLetter[] @relation("GeneratedLetterCreatedBy")
  aiMemoryPreference     AiMemoryPreference?
  aiUserMemories         AiUserMemory[]
  aiContextFiles         AiContextFile[]
}

// ─── Steward AI Memory & Context ─────────────────────────────────────────────

model AiMemoryPreference {
  id                 String   @id @default(cuid())
  organizationId     String
  userId             String   @unique
  memoryEnabled      Boolean  @default(true)
  fileContextEnabled Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model AiUserMemory {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  title          String   @db.VarChar(160)
  content        String   @db.Text
  category       String   @default("preference") @db.VarChar(60)
  source         String   @default("manual") @db.VarChar(60)
  confidence     Float    @default(0.75)
  active         Boolean  @default(true)
  workspaceScope String?  @db.VarChar(40)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId, active])
  @@index([organizationId, userId, category])
  @@index([organizationId, userId, workspaceScope])
}

model AiContextFile {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  fileName       String   @db.VarChar(255)
  displayName    String   @db.VarChar(255)
  mimeType       String   @db.VarChar(120)
  fileType       String   @db.VarChar(40)
  sizeBytes      Int      @default(0)
  workspaceScope String?  @db.VarChar(40)
  description    String?  @db.Text
  tags           Json?
  indexingStatus String   @default("pending") @db.VarChar(40)
  active         Boolean  @default(true)
  extractedText  String?  @db.LongText
  contentHash    String?  @db.VarChar(128)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  indexedAt      DateTime?

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks       AiContextChunk[]

  @@index([organizationId, userId, active])
  @@index([organizationId, userId, workspaceScope])
  @@index([organizationId, userId, indexingStatus])
}

model AiContextChunk {
  id             String   @id @default(cuid())
  organizationId String
  fileId         String
  userId         String
  chunkIndex     Int
  chunkText      String   @db.Text
  tokenEstimate  Int      @default(0)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  file         AiContextFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([fileId, chunkIndex])
  @@index([organizationId, userId])
  @@index([organizationId, fileId])
}

// ─── Constituent (Donor/Volunteer/Member) ─────────────────────────────────────

model Constituent {
  id             String          @id @default(cuid())
  organizationId String
  type           ConstituentType @default(DONOR)
  donorStatus    DonorStatus     @default(NEW)

  // Contact info
  prefix    String?
  firstName String
  lastName  String
  displayName String?
  organizationName String?
  contactFirstName String?
  contactLastName String?
  contactTitle String?
  entityKind String @default("PERSON")
  organizationCategory String?
  email     String?
  email2    String?
  phone     String?
  phone2    String?
  mobile    String?

  // Address
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  zip          String?
  country      String  @default("US")

  // Profile
  birthDate  DateTime?
  employer   String?
  occupation String?
  notes      String?   @db.Text
  avatarUrl  String?
  externalId String?   @db.VarChar(100) // Source system ID (e.g. DirID from eKYROS) for dedup on re-import

  // Household
  householdId      String?
  isPrimaryContact Boolean @default(true)

  // Communication preferences
  doNotEmail   Boolean @default(false)
  doNotCall    Boolean @default(false)
  doNotMail    Boolean @default(false)
  doNotContact Boolean @default(false)
  emailOptOut  Boolean @default(false)

  // Giving summary (denormalized for performance)
  totalLifetimeGiving Decimal   @default(0) @db.Decimal(12, 2)
  totalYtdGiving      Decimal   @default(0) @db.Decimal(12, 2)
  firstGiftDate       DateTime?
  lastGiftDate        DateTime?
  lastGiftAmount      Decimal?  @db.Decimal(10, 2)
  giftCount           Int       @default(0)
  engagementScore     Int       @default(0) // 0-100

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id])
  household        Household?        @relation("HouseholdMembers", fields: [householdId], references: [id])
  headOf           Household?        @relation("HouseholdHead")
  primaryForGroups ConstituentGroup[] @relation("PrimaryConstituentGroup")
  groupMemberships ConstituentGroupMember[]
  donations        Donation[]
  tasks            Task[]
  meetings         Meeting[]
  tags             ConstituentTag[]
  activities       Activity[]
  eventAttendances EventAttendance[]
  eventOrders      EventOrder[]
  eventGuests      EventGuest[]
  eventSponsors    EventSponsor[]
  volunteerHours   VolunteerHour[]
  pledges          Pledge[]

  // ─── Compassion CRM link (optional shared-person layer) ───────────────────
  compassionClients CompassionClient[]

  // ─── Steward Paths enrollments/drafts ───────────────────────────────────
  stewardPathEnrollments StewardPathEnrollment[]
  stewardPathEmailDrafts StewardPathEmailDraft[]

  // ─── Donor CRM Letters & Printables relations ──────────────────────────
  generatedLetters GeneratedLetter[]
  emailSubscriptions EmailSubscription[]
  emailConsentEvents EmailConsentEvent[]
  emailSuppressions EmailSuppression[]
  emailSendRecipients EmailSendRecipient[]
}

model ConstituentGroup {
  id                   String   @id @default(cuid())
  organizationId       String
  name                 String
  groupType            String   @default("ORGANIZATION")
  description          String?  @db.Text
  primaryConstituentId String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  organization      Organization             @relation(fields: [organizationId], references: [id])
  primaryConstituent Constituent?            @relation("PrimaryConstituentGroup", fields: [primaryConstituentId], references: [id], onDelete: SetNull)
  members           ConstituentGroupMember[]

  @@index([organizationId, groupType])
  @@index([primaryConstituentId])
}

model ConstituentGroupMember {
  id                String   @id @default(cuid())
  groupId           String
  constituentId     String
  relationshipLabel String?
  isPrimary         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  group       ConstituentGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  constituent Constituent      @relation(fields: [constituentId], references: [id], onDelete: Cascade)

  @@unique([groupId, constituentId])
  @@index([constituentId])
}

model Household {
  id                String   @id @default(cuid())
  name              String
  headConstituentId String?  @unique
  addressLine1      String?
  addressLine2      String?
  city              String?
  state             String?
  zip               String?
  country           String   @default("US")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  head    Constituent?  @relation("HouseholdHead", fields: [headConstituentId], references: [id])
  members Constituent[] @relation("HouseholdMembers")
}

model Tag {
  id          String   @id @default(cuid())
  name        String
  color       String   @default("#16a34a")
  description String?
  createdAt   DateTime @default(now())

  constituents ConstituentTag[]
}

model ConstituentTag {
  constituentId String
  tagId         String
  createdAt     DateTime @default(now())

  constituent Constituent @relation(fields: [constituentId], references: [id], onDelete: Cascade)
  tag         Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([constituentId, tagId])
}

// ─── Donations & Pledges ─────────────────────────────────────────────────────

model Donation {
  id            String  @id @default(cuid())
  constituentId String
  campaignId    String?
  designationId String?
  pledgeId      String?
  eventId       String?

  amount        Decimal        @db.Decimal(10, 2)
  feeAmount     Decimal        @default(0) @db.Decimal(8, 2)
  date          DateTime       @default(now())
  paymentMethod PaymentMethod  @default(ONLINE)
  status        DonationStatus @default(COMPLETED)
  checkNumber   String?
  transactionId String?

  isRecurring  Boolean             @default(false)
  frequency    RecurringFrequency?
  nextGiftDate DateTime?

  receiptNumber        String?   @unique
  receiptSentAt        DateTime?
  acknowledgmentSentAt DateTime?
  taxDeductible        Boolean   @default(true)

  inKindDescription String?
  notes             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  constituent      Constituent       @relation(fields: [constituentId], references: [id])
  campaign         Campaign?         @relation(fields: [campaignId], references: [id])
  designation      Designation?      @relation(fields: [designationId], references: [id])
  pledge           Pledge?           @relation(fields: [pledgeId], references: [id])
  event            Event?            @relation(fields: [eventId], references: [id])
  activities       Activity[]
  // QuickBooks sync queue items linked to this donation
  qbSyncQueueItems QBSyncQueueItem[]

  // ─── Donor CRM Letters & Printables relations ──────────────────────────
  generatedLetters GeneratedLetter[]
}

model Pledge {
  id            String  @id @default(cuid())
  constituentId String
  campaignId    String?
  designationId String?

  totalAmount Decimal             @db.Decimal(10, 2)
  paidAmount  Decimal             @default(0) @db.Decimal(10, 2)
  startDate   DateTime
  endDate     DateTime?
  frequency   RecurringFrequency?
  notes       String?
  active      Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  constituent Constituent  @relation(fields: [constituentId], references: [id])
  campaign    Campaign?    @relation(fields: [campaignId], references: [id])
  designation Designation? @relation(fields: [designationId], references: [id])
  payments    Donation[]
}

model Designation {
  id          String   @id @default(cuid())
  name        String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  donations Donation[]
  pledges   Pledge[]
}

// ─── Campaigns ───────────────────────────────────────────────────────────────

model Campaign {
  id             String           @id @default(cuid())
  organizationId String
  name           String
  description    String?          @db.Text
  category       CampaignCategory @default(ANNUAL_FUND)
  goal           Decimal?         @db.Decimal(12, 2)
  startDate      DateTime
  endDate        DateTime?
  active         Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  donations    Donation[]
  pledges      Pledge[]

  // ─── Donor CRM Letters & Printables relations ──────────────────────────
  generatedLetters GeneratedLetter[]
}

// ─── Tasks ───────────────────────────────────────────────────────────────────

model Task {
  id            String  @id @default(cuid())
  organizationId String?
  constituentId String?
  assigneeId    String?
  createdById   String?
  completedById String?

  title       String
  description String?      @db.Text
  type        TaskType     @default(FOLLOW_UP)
  status      TaskStatus   @default(PENDING)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  reminderAt  DateTime?
  snoozedUntil DateTime?
  archivedAt  DateTime?
  completedAt DateTime?
  outcome     String?      @db.Text
  sourceModule String?
  sourceType   String?
  sourceId     String?
  checklistJson Json?
  metadata      Json?
  generatedLetterId       String?
  stewardPathEnrollmentId String?
  stewardPathStepRunId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  constituent Constituent? @relation(fields: [constituentId], references: [id])
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdBy   User?        @relation("TaskCreator", fields: [createdById], references: [id])
  completedBy User?        @relation("TaskCompletedBy", fields: [completedById], references: [id])
  activities  Activity[]
  meeting     Meeting?     @relation(fields: [meetingId], references: [id])
  meetingId   String?

  @@index([organizationId])
  @@index([assigneeId, status, dueDate])
  @@index([status, archivedAt])
  @@index([sourceModule, sourceType, sourceId])
  @@index([generatedLetterId])
  @@index([stewardPathEnrollmentId])
  @@index([stewardPathStepRunId])
}

model TaskTemplatePreset {
  id                String   @id @default(cuid())
  organizationId    String
  name              String
  title             String
  taskType          TaskType @default(FOLLOW_UP)
  defaultPriority   TaskPriority @default(MEDIUM)
  defaultDueOffsetDays Int   @default(1)
  description       String?  @db.Text
  checklistJson     Json?
  suggestedReminderHours Int?
  workflowCategory  String?
  isBuiltIn         Boolean  @default(false)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, isActive])
  @@unique([organizationId, name])
}

model Notification {
  id            String             @id @default(cuid())
  organizationId String
  userId        String
  module        String
  sourceType    String
  sourceId      String?
  title         String
  message       String             @db.Text
  href          String
  severity      NotificationSeverity @default(MEDIUM)
  status        NotificationStatus @default(UNREAD)
  actionLabel   String?
  metadata      Json?
  createdAt     DateTime           @default(now())
  readAt        DateTime?
  dismissedAt   DateTime?
  snoozedUntil  DateTime?
  expiresAt     DateTime?
  archivedAt    DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation("NotificationUser", fields: [userId], references: [id])

  @@index([organizationId, userId, status])
  @@index([organizationId, userId, createdAt])
  @@index([userId, snoozedUntil])
  @@index([sourceType, sourceId])
}

// ─── Meetings ─────────────────────────────────────────────────────────────────

model Meeting {
  id             String @id @default(cuid())
  organizationId String

  title  String
  type   MeetingType   @default(OTHER)
  status MeetingStatus @default(SCHEDULED)

  startTime DateTime
  endTime   DateTime?
  timezone  String    @default("America/Chicago")

  locationType MeetingLocationType @default(IN_PERSON)
  location     String?
  meetingUrl   String?

  purpose      String? @db.Text
  notes        String? @db.Text
  privateNotes String? @db.Text
  outcome      String? @db.Text

  followUpNeeded Boolean @default(false)

  // Relations
  constituentId   String?
  assignedStaffId String?
  createdById     String?

  completedAt DateTime?
  canceledAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  organization  Organization @relation(fields: [organizationId], references: [id])
  constituent   Constituent? @relation(fields: [constituentId], references: [id])
  assignedStaff User?        @relation("MeetingAssignee", fields: [assignedStaffId], references: [id])
  createdBy     User?        @relation("MeetingCreator", fields: [createdById], references: [id])
  tasks         Task[]
  activities    Activity[]
}

// ─── Events ──────────────────────────────────────────────────────────────────

model Event {
  id             String          @id @default(cuid())
  organizationId String
  name           String
  description    String?         @db.Text
  type           EventType       @default(OTHER)
  status         EventStatus     @default(DRAFT)
  visibility     EventVisibility @default(PUBLIC)

  // Location details
  location   String?
  address    String?
  city       String?
  state      String?
  zip        String?
  virtualUrl String?

  // Date & time
  startDate            DateTime
  endDate              DateTime?
  registrationDeadline DateTime?

  // Capacity & goals
  capacity         Int?
  registrationGoal Int?
  revenueGoal      Decimal? @db.Decimal(10, 2)

  // Ownership & management
  ownerId       String?
  internalNotes String? @db.Text

  // Legacy active field (consider deprecating in favor of status)
  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization   Organization      @relation(fields: [organizationId], references: [id])
  owner          User?             @relation(fields: [ownerId], references: [id])
  ticketTypes    TicketType[]
  orders         EventOrder[]
  guests         EventGuest[]
  tables         EventTable[]
  tableSeats     EventTableSeat[]
  guestInvites   EventGuestInvite[]
  tableAccessTokens EventTableAccessToken[]
  checkInRecords EventCheckInRecord[]
  checkInExceptions EventCheckInException[]
  emailLogs      EventEmailLog[]
  sponsors       EventSponsor[]
  donations      Donation[]
  activities     Activity[]
  volunteerHours VolunteerHour[]
  // Legacy - kept for backward compatibility during migration
  attendances    EventAttendance[]

  // ─── Donor CRM Letters & Printables relations ──────────────────────────
  generatedLetters GeneratedLetter[]
}

model TicketType {
  id            String   @id @default(cuid())
  eventId       String
  name          String
  description   String?  @db.Text
  price         Decimal  @db.Decimal(8, 2)
  capacity      Int?
  available     Int?
  sortOrder     Int      @default(0)
  active        Boolean  @default(true)
  // Table ticket support (from GalaSoft concepts)
  isTable       Boolean  @default(false)
  seatsIncluded Int      @default(1)
  minPerOrder   Int      @default(1)
  maxPerOrder   Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  event      Event            @relation(fields: [eventId], references: [id])
  orderItems EventOrderItem[]
  guests     EventGuest[]
}

model EventOrder {
  id            String      @id @default(cuid())
  eventId       String
  constituentId String
  orderNumber   String      @unique
  status        OrderStatus @default(PENDING)

  totalAmount Decimal @db.Decimal(10, 2)
  feeAmount   Decimal @default(0) @db.Decimal(8, 2)

  paymentMethod PaymentMethod?
  transactionId String?
  paidAt        DateTime?

  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event       Event            @relation(fields: [eventId], references: [id])
  constituent Constituent      @relation(fields: [constituentId], references: [id])
  items       EventOrderItem[]
  guests      EventGuest[]
}

model EventOrderItem {
  id           String   @id @default(cuid())
  orderId      String
  ticketTypeId String
  quantity     Int      @default(1)
  unitPrice    Decimal  @db.Decimal(8, 2)
  totalPrice   Decimal  @db.Decimal(8, 2)
  createdAt    DateTime @default(now())

  order      EventOrder @relation(fields: [orderId], references: [id])
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])
}

model EventGuest {
  id            String  @id @default(cuid())
  eventId       String
  orderId       String?
  constituentId String?
  ticketTypeId  String?
  tableId       String?
  seatId        String? @unique

  // Guest details (can be independent of constituent)
  firstName String?
  lastName  String?
  email     String?
  phone     String?

  // Check-in
  checkedIn   Boolean   @default(false)
  checkedInAt DateTime?
  checkinCode String?   @unique

  // Registration status fields (from GalaSoft concepts)
  paymentStatus  EventGuestPaymentStatus @default(DUE)
  rsvpStatus     EventGuestRsvpStatus    @default(PENDING)
  mealPreference String?
  seatNumber     Int?
  partyName      String?

  // Dietary & accessibility
  dietaryRestrictions String?
  specialNeeds        String?
  notes               String? @db.Text

  // Invite and source tracking
  source           EventGuestSource @default(ADMIN)
  qrTokenHash      String?
  qrTokenExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event       Event        @relation(fields: [eventId], references: [id])
  order       EventOrder?  @relation(fields: [orderId], references: [id])
  constituent Constituent? @relation(fields: [constituentId], references: [id])
  ticketType  TicketType?  @relation(fields: [ticketTypeId], references: [id])
  table       EventTable?  @relation(fields: [tableId], references: [id])
  seat        EventTableSeat? @relation(fields: [seatId], references: [id])
  invites     EventGuestInvite[]
  checkInRecords EventCheckInRecord[]
  checkInExceptions EventCheckInException[]
  emailLogs   EventEmailLog[]

  @@index([eventId, rsvpStatus])
  @@index([eventId, source])
  @@index([tableId])
  @@index([seatId])
}

model EventTable {
  id          String   @id @default(cuid())
  eventId     String
  tableUid    String   @default(cuid()) @unique
  publicCode  String?
  name        String
  capacity    Int      @default(10)
  status      EventTableStatus @default(DRAFT)
  notes       String?  @db.Text
  // Seating layout fields (from GalaSoft concepts)
  tableNumber Int?
  isSponsored Boolean  @default(false)
  sponsorName String?
  hostName    String?
  hostEmail   String?
  hostPhone   String?
  accessTokenHash      String?
  accessTokenExpiresAt DateTime?
  xPosition   Int      @default(0)
  yPosition   Int      @default(0)
  shape       String   @default("round")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event         Event                   @relation(fields: [eventId], references: [id])
  guests        EventGuest[]
  seats         EventTableSeat[]
  guestInvites  EventGuestInvite[]
  accessTokens  EventTableAccessToken[]
  checkInRecords EventCheckInRecord[]
  checkInExceptions EventCheckInException[]
  emailLogs     EventEmailLog[]

  @@unique([eventId, publicCode])
  @@index([eventId, status])
}

model EventTableSeat {
  id         String             @id @default(cuid())
  eventId    String
  tableId    String
  seatNumber Int
  status     EventTableSeatStatus @default(EMPTY)
  notes      String?            @db.Text
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  event       Event             @relation(fields: [eventId], references: [id])
  table       EventTable        @relation(fields: [tableId], references: [id])
  guest       EventGuest?
  invites     EventGuestInvite[]
  checkInRecords EventCheckInRecord[]
  checkInExceptions EventCheckInException[]

  @@unique([tableId, seatNumber])
  @@index([eventId, tableId])
  @@index([eventId, status])
}

model EventGuestInvite {
  id                 String                @id @default(cuid())
  eventId            String
  tableId            String
  seatId             String?
  guestId            String?
  invitedByUserId    String?
  invitedByHostEmail String?
  inviteEmail        String?
  invitePhone        String?
  tokenHash          String
  status             EventGuestInviteStatus @default(CREATED)
  openedAt           DateTime?
  completedAt        DateTime?
  expiresAt          DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  event         Event          @relation(fields: [eventId], references: [id])
  table         EventTable     @relation(fields: [tableId], references: [id])
  seat          EventTableSeat? @relation(fields: [seatId], references: [id])
  guest         EventGuest?    @relation(fields: [guestId], references: [id])
  emailLogs     EventEmailLog[]

  @@index([eventId, status])
  @@index([tableId, status])
  @@index([seatId])
  @@index([tokenHash])
}

model EventTableAccessToken {
  id         String                     @id @default(cuid())
  eventId    String
  tableId    String
  hostEmail  String
  tokenHash  String
  status     EventTableAccessTokenStatus @default(ACTIVE)
  expiresAt  DateTime
  lastUsedAt DateTime?
  createdAt  DateTime                   @default(now())
  updatedAt  DateTime                   @updatedAt

  event Event      @relation(fields: [eventId], references: [id])
  table EventTable @relation(fields: [tableId], references: [id])

  @@index([eventId, tableId, status])
  @@index([tokenHash])
  @@index([hostEmail])
}

model EventCheckInRecord {
  id                String            @id @default(cuid())
  eventId           String
  guestId           String?
  tableId           String?
  seatId            String?
  method            EventCheckInMethod
  status            EventCheckInStatus @default(CHECKED_IN)
  checkedInByUserId String?
  checkInDeviceId   String?
  checkedInAt       DateTime          @default(now())
  reversedAt        DateTime?
  reversedByUserId  String?
  notes             String?           @db.Text

  event           Event          @relation(fields: [eventId], references: [id])
  guest           EventGuest?    @relation(fields: [guestId], references: [id])
  table           EventTable?    @relation(fields: [tableId], references: [id])
  seat            EventTableSeat? @relation(fields: [seatId], references: [id])

  @@index([eventId, checkedInAt])
  @@index([eventId, status])
  @@index([eventId, guestId])
  @@index([eventId, tableId])
}

model EventCheckInException {
  id              String                        @id @default(cuid())
  eventId         String
  guestId         String?
  tableId         String?
  seatId          String?
  guestName       String?
  claimedTable    String?
  claimedEmail    String?
  claimedPhone    String?
  issueType       EventCheckInExceptionIssueType
  status          EventCheckInExceptionStatus @default(OPEN)
  notes           String?                      @db.Text
  createdByUserId String?
  resolvedByUserId String?
  createdAt       DateTime                     @default(now())
  resolvedAt      DateTime?

  event          Event          @relation(fields: [eventId], references: [id])
  guest          EventGuest?    @relation(fields: [guestId], references: [id])
  table          EventTable?    @relation(fields: [tableId], references: [id])
  seat           EventTableSeat? @relation(fields: [seatId], references: [id])

  @@index([eventId, status])
  @@index([eventId, issueType])
  @@index([eventId, createdAt])
}

model EventEmailLog {
  id                String            @id @default(cuid())
  eventId           String
  tableId           String?
  guestId           String?
  inviteId          String?
  type              EventEmailLogType
  recipientEmail    String
  status            EventEmailLogStatus @default(QUEUED)
  subject           String?
  providerMessageId String?
  errorMessage      String?           @db.Text
  queuedAt          DateTime?
  sentAt            DateTime?
  openedAt          DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  event  Event            @relation(fields: [eventId], references: [id])
  table  EventTable?      @relation(fields: [tableId], references: [id])
  guest  EventGuest?      @relation(fields: [guestId], references: [id])
  invite EventGuestInvite? @relation(fields: [inviteId], references: [id])

  @@index([eventId, type, status])
  @@index([tableId])
  @@index([guestId])
  @@index([inviteId])
  @@index([recipientEmail])
}

model EventSponsor {
  id            String           @id @default(cuid())
  eventId       String
  constituentId String
  level         SponsorshipLevel
  amount        Decimal          @db.Decimal(10, 2)
  benefits      String?          @db.Text
  logoUrl       String?
  websiteUrl    String?
  notes         String?          @db.Text
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  event       Event       @relation(fields: [eventId], references: [id])
  constituent Constituent @relation(fields: [constituentId], references: [id])
}

// Legacy EventAttendance - kept for backward compatibility during migration
// TODO: Migrate data to EventGuest and deprecate
model EventAttendance {
  id            String    @id @default(cuid())
  eventId       String
  constituentId String
  checkedIn     Boolean   @default(false)
  checkedInAt   DateTime?
  ticketType    String?
  amountPaid    Decimal?  @db.Decimal(8, 2)
  createdAt     DateTime  @default(now())

  event       Event       @relation(fields: [eventId], references: [id])
  constituent Constituent @relation(fields: [constituentId], references: [id])
}

// ─── OyamaWebMaster ──────────────────────────────────────────────────────────

model WebmasterSite {
  id             String  @id @default(cuid())
  organizationId String
  createdById    String?

  name        String
  slug        String
  domain      String?
  description String?             @db.Text
  status      WebmasterSiteStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id])
  createdBy    User?           @relation("WebmasterSiteCreator", fields: [createdById], references: [id], onDelete: SetNull)
  pages        WebmasterPage[]

  @@unique([organizationId, slug])
  @@index([organizationId, status])
}

model WebmasterPage {
  id             String  @id @default(cuid())
  organizationId String
  siteId         String
  createdById    String?
  updatedById    String?

  title          String
  slug           String
  path           String
  status         WebmasterPageStatus @default(DRAFT)
  contentJson    Json?
  seoTitle       String?
  seoDescription String?
  publishedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id])
  site         WebmasterSite @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdBy    User?         @relation("WebmasterPageCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?         @relation("WebmasterPageUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([siteId, slug])
  @@unique([siteId, path])
  @@index([organizationId, status, updatedAt])
}

// ─── Volunteers ──────────────────────────────────────────────────────────────

model VolunteerHour {
  id            String   @id @default(cuid())
  constituentId String
  eventId       String?
  hours         Decimal  @db.Decimal(6, 2)
  description   String?
  date          DateTime
  createdAt     DateTime @default(now())

  constituent Constituent @relation(fields: [constituentId], references: [id])
  event       Event?      @relation(fields: [eventId], references: [id])
}

// ─── Activity Timeline ────────────────────────────────────────────────────────

model Activity {
  id            String  @id @default(cuid())
  constituentId String?
  donationId    String?
  taskId        String?
  meetingId     String?
  userId        String?
  eventId       String?

  type        ActivityType
  description String       @db.Text
  metadata    Json?
  createdAt   DateTime     @default(now())

  constituent Constituent? @relation(fields: [constituentId], references: [id])
  donation    Donation?    @relation(fields: [donationId], references: [id])
  task        Task?        @relation(fields: [taskId], references: [id])
  meeting     Meeting?     @relation(fields: [meetingId], references: [id])
  user        User?        @relation(fields: [userId], references: [id])
  event       Event?       @relation(fields: [eventId], references: [id])
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique @db.VarChar(512)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String?
  userId         String?
  action         String // CREATE, UPDATE, DELETE, LOGIN, LOGOUT, etc.
  entity         String? // Constituent, Donation, User, etc.
  entityId       String?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model WatchdogFeedbackTicket {
  id                  String   @id @default(cuid())
  organizationId      String
  ticketNumber        String   @unique

  type                String   @db.VarChar(40)
  status              String   @default("new") @db.VarChar(40)
  priority            String   @default("normal") @db.VarChar(20)
  crmScope            String   @default("unknown") @db.VarChar(20)

  pageUrl             String
  routePath           String?
  pageTitle           String?

  submittedByUserId   String?
  submittedByName     String?
  submittedByEmail    String?

  whatTryingToDo      String?  @db.Text
  whatHappened        String?  @db.Text
  expectedResult      String?  @db.Text
  extraComments       String?  @db.Text

  featureTitle        String?
  featureProblem      String?  @db.Text
  featureAudience     String?
  featureRequestedChange String? @db.Text
  importance          String?  @db.VarChar(20)

  browserInfo         String?
  deviceInfo          String?
  appVersion          String?
  environment         String?  @db.VarChar(20)

  assignedDeveloperId String?
  assignedToPersonId  String?

  developerNotes      String?  @db.Text
  resolutionNotes     String?  @db.Text

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  resolvedAt          DateTime?

  submittedByUser     User?    @relation("FeedbackSubmittedBy", fields: [submittedByUserId], references: [id], onDelete: SetNull)
  assignedDeveloper   User?    @relation("FeedbackAssignedDeveloper", fields: [assignedDeveloperId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([organizationId, status])
  @@index([organizationId, type])
  @@index([organizationId, priority])
  @@index([organizationId, crmScope])
  @@index([organizationId, submittedByUserId])
  @@index([organizationId, assignedDeveloperId])
}

enum HrmLocationStatus {
  ACTIVE
  INACTIVE
}

enum HrmMessagePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum HrmMessageKind {
  DIRECT
  ANNOUNCEMENT
}

model HrmLocation {
  id             String            @id @default(cuid())
  organizationId String

  name         String
  code         String?
  timezone     String            @default("America/Chicago")
  status       HrmLocationStatus @default(ACTIVE)
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  zip          String?
  notes        String?           @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization       Organization @relation(fields: [organizationId], references: [id])
  defaultForSettings HrmSetting[] @relation("HrmSettingDefaultLocation")

  @@unique([organizationId, name])
  @@unique([organizationId, code])
  @@index([organizationId, status])
}

model HrmMessage {
  id             String             @id @default(cuid())
  organizationId String
  senderUserId   String
  recipientUserId String?
  recipientRole  String?
  kind           HrmMessageKind     @default(DIRECT)
  priority       HrmMessagePriority @default(NORMAL)
  broadcastAll   Boolean            @default(false)

  title      String
  body       String @db.Text
  readAt     DateTime?
  archivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  sender       User         @relation("HrmMessageSender", fields: [senderUserId], references: [id], onDelete: Cascade)
  recipient    User?        @relation("HrmMessageRecipient", fields: [recipientUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([organizationId, recipientUserId, readAt])
  @@index([organizationId, recipientRole, readAt])
  @@index([organizationId, senderUserId])
  @@index([organizationId, kind])
}

model HrmSetting {
  id                        String  @id @default(cuid())
  organizationId            String  @unique
  defaultTimezone           String  @default("America/Chicago")
  defaultLocationId         String?
  allowCompassionAssignmentSync Boolean @default(true)
  requireSchedulableFlag    Boolean @default(true)
  messageDigestEnabled      Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id])
  defaultLocation HrmLocation? @relation("HrmSettingDefaultLocation", fields: [defaultLocationId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([defaultLocationId])
}

